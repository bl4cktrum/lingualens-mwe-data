{
  "name": "lingualens-mwe-data",
  "version": "1.0.0",
  "description": "MWE bundle build pipeline for the LinguaLens browser extension",
  "private": true,
  "type": "module",
  "scripts": {
    "build-bundle": "tsx tools/cli.ts",
    "build-all": "tsx tools/cli.ts --all",
